{
  "name": "project-loom",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "The Loom — Hyper-realistic experience orchestration engine",
  "workspaces": [
    "contracts/*",
    "fabrics/*",
    "tools/*"
  ],
  "scripts": {
    "build": "tsc --build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write '**/*.{ts,tsx,json,md}'",
    "format:check": "prettier --check '**/*.{ts,tsx,json,md}'",
    "typecheck": "tsc --build",
    "clean": "tsc --build --clean",
    "check": "npm run typecheck && npm run lint && npm run test",
    "dev": "tsx watch"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@msgpack/msgpack": "^3.1.3",
    "@types/google-protobuf": "^3.15.12",
    "@types/node": "^25.3.5",
    "@types/pg": "^8.18.0",
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^10.0.2",
    "flatbuffers": "^25.9.23",
    "globals": "^17.4.0",
    "pino": "^10.3.1",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "uuid": "^13.0.0",
    "vitest": "^4.0.18",
    "zod": "^4.3.6"
  },
  "dependencies": {
    "@fastify/websocket": "^11.2.0",
    "@grpc/grpc-js": "^1.14.3",
    "@grpc/proto-loader": "^0.8.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.71.0",
    "@opentelemetry/exporter-trace-otlp-grpc": "^0.213.0",
    "@opentelemetry/sdk-node": "^0.213.0",
    "@opentelemetry/sdk-trace-node": "^2.6.0",
    "@temporalio/client": "^1.15.0",
    "@temporalio/worker": "^1.15.0",
    "fastify": "^5.8.2",
    "ioredis": "^5.10.0",
    "pg": "^8.20.0",
    "prom-client": "^15.1.3",
    "sodium-native": "^5.1.0"
  }
}
