{
  "name": "project-loom",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "The Loom — Hyper-realistic experience orchestration engine",
  "workspaces": [
    "contracts/*",
    "fabrics/*",
    "tools/*"
  ],
  "scripts": {
    "build": "tsc --build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write '**/*.{ts,tsx,json,md}'",
    "format:check": "prettier --check '**/*.{ts,tsx,json,md}'",
    "typecheck": "tsc --build --noEmit",
    "clean": "tsc --build --clean",
    "check": "npm run typecheck && npm run lint && npm run test",
    "dev": "tsx watch"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "@msgpack/msgpack": "^3.1.3",
    "@types/node": "^25.3.5",
    "@types/uuid": "^10.0.0",
    "eslint": "^10.0.2",
    "flatbuffers": "^25.9.23",
    "pino": "^10.3.1",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "uuid": "^13.0.0",
    "vitest": "^4.0.18",
    "zod": "^4.3.6"
  }
}
