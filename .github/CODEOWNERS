fabrics/loom-core/               @loom-core-guild
fabrics/shuttle/                  @shuttle-guild
fabrics/silfen-weave/            @silfen-weave-guild
fabrics/nakama-fabric/           @nakama-guild
fabrics/bridge-loom-ue5/         @bridge-guild
fabrics/inspector/               @inspector-guild
fabrics/selvage/                 @selvage-guild
fabrics/dye-house/               @security-guild
fabrics/archive/                 @archive-guild

# Tools
tools/                           @the-weaver

# Tests
tests/                           @the-weaver
